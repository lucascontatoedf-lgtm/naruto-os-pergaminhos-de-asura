[node name="FlorestaDaNevoa" type="Node2D"]

; ----------------------------------------------------------------------------
; AMBIENTE — Tsukuyomi tint + Lua parallax (Fase 1 placeholders)
;
; CanvasModulate: multiplica a cor de TODOS os CanvasItem filhos pelo tom rosa-roxo.
; Tudo no nível (chão, plataformas, troncos, player, zabuza, fog) ganha esse filtro
; sem custo de render — é o jeito canônico de fazer "atmosfera global" em 2D no Godot.
; Nome explícito ($CanvasModulate) pra futuro level script poder fazer:
;   var tw := create_tween(); tw.tween_property($CanvasModulate, "color", Color(...), 1.0)
; durante transição pra BOSS_BATTLE state — gancho preparado, sem código agora.
;
; ParallaxBackground: Lua placeholder (Polygon2D circular 12-gon) com halo sutil.
; motion_scale = (0, 0) → Lua FIXA no viewport, sempre visível upper-right.
; Padrão de jogos com céu noturno (Hollow Knight, Celeste) — "a Lua sempre te observa"
; combina com o conceito de Tsukuyomi.
;
; ATENÇÃO COORDENADAS: ParallaxLayer com motion_scale=(0,0) usa CanvasLayer space:
;   - origem (0,0) = canto SUPERIOR ESQUERDO do viewport
;   - Y CRESCE PRA BAIXO (positivo = mais abaixo, negativo = ACIMA da tela)
;   - Coords em PIXELS do viewport (não world space)
; Position (900, 150) calibrada pra viewport default 1152x648:
;   - x=900: 252px da borda direita (margem segura, halo raio 140 cabe)
;   - y=150: 150px abaixo do topo (halo extends y=10 a y=290, todo visível)
; Substituir por Sprite2D real quando tivermos arte da Lua/Sharingan.
; ----------------------------------------------------------------------------
[node name="CanvasModulate" type="CanvasModulate" parent="."]
color = Color(0.85, 0.65, 0.75, 1)

[node name="ParallaxBackground" type="ParallaxBackground" parent="."]

[node name="MoonLayer" type="ParallaxLayer" parent="ParallaxBackground"]
motion_scale = Vector2(0, 0)

[node name="MoonHalo" type="Polygon2D" parent="ParallaxBackground/MoonLayer"]
position = Vector2(900, 150)
polygon = PackedVector2Array(140, 0, 121, 70, 70, 121, 0, 140, -70, 121, -121, 70, -140, 0, -121, -70, -70, -121, 0, -140, 70, -121, 121, -70)
color = Color(0.85, 0.4, 0.3, 0.22)
z_index = -2

[node name="Moon" type="Polygon2D" parent="ParallaxBackground/MoonLayer"]
position = Vector2(900, 150)
polygon = PackedVector2Array(100, 0, 87, 50, 50, 87, 0, 100, -50, 87, -87, 50, -100, 0, -87, -50, -50, -87, 0, -100, 50, -87, 87, -50)
color = Color(0.95, 0.6, 0.5, 1)
