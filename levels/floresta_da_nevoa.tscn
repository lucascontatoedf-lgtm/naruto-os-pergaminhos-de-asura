[gd_scene load_steps=9 format=3]

; ============================================================================
; Floresta da Névoa — Arena protótipo Fase 1 (Semana 2 - Level Design)
;
; Layout: 3000px de largura (-1500 a +1500), chão a y=400 (surface y=368).
; Floor segmentado em LEFT + RIGHT com um PIT de 300px no meio (x=100 a 400)
; pra testar kill_zone, double-jump, dash e AMBUSH em situação tática.
;
; Verticalidade progressiva (lado esquerdo, do chão até o topo):
;   - PlatLow_A   y=284 (top=268)  — pulo simples
;   - PlatMid_B   y=184 (top=168)  — requer double-jump
;   - PlatHigh_C  y=104 (top=88)   — verticalidade máxima
;
; Lado direito (após o pit, arena do boss):
;   - PlatMid_D   y=184 — descanso após travessia
;   - PlatHigh_E  y=104 — vantage point sobre o boss
;
; Player spawn: extremo esquerdo (-1400, 200) — cai e aprende controles
; Zabuza spawn: lado direito (1200, 368) — fora do detection_radius (500px)
;               até Player atravessar o pit
;
; Estilo: Polygon2D + StaticBody2D (mesma convenção do test_stage). TileMapLayer
; fica pra quando tivermos sprites HD (Semana 3 polish).
; ============================================================================

[ext_resource type="PackedScene" path="res://scenes/player/player.tscn" id="1_player"]
[ext_resource type="PackedScene" path="res://scenes/entities/zabuza.tscn" id="2_zabuza"]

