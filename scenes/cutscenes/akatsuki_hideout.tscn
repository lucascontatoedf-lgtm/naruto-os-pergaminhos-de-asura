[gd_scene load_steps=6 format=3]

; ============================================================================
; AkatsukiHideout — cutscene do esconderijo (Zona 2, easter egg SUGESTOES.md #05)
;
; ESTRUTURA:
;   AkatsukiHideout (Node2D) — script: akatsuki_hideout.gd
;   └── UILayer (CanvasLayer)
;       └── Background (TextureRect, anchor full_rect, KEEP_ASPECT_COVERED)
;
; OBS: TextureRect (Control) em Node2D usa coords de mundo. UILayer (CanvasLayer)
; é necessário pro background renderizar full-screen independente de camera/player.
;
; SWAP DE FRAMES — controle DIRETO pelo script (sem AnimationPlayer):
;   - Cena abre com gedo2 (Pain mão na cabeça) — setado aqui no .tscn
;   - akatsuki_hideout.gd escuta DialogueManager.line_advanced(index)
;   - Ao chegar na linha índice 2 ("Pain: Inesperado.") troca pra gedo3 (Pain sentado)
;   - Permanece estático até fim do diálogo
;
; gedo3 NÃO está como ext_resource aqui — script faz preload() direto.
;
; INTEGRAÇÃO FUTURA: KamuiTrigger (já existe em scripts/components/) deve ser
; instanciado como filho desta cena pra ouvir DialogueManager.kamui_triggered
; ao fim de "akatsuki_encontro" e executar fade+teleporte+saida.
; ============================================================================

[ext_resource type="Script" path="res://scripts/cutscenes/akatsuki_hideout.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/backgrounds/akatsuki/guedomazo_pain_konan_tobi_naruto2.png" id="2_gedo2"]
[ext_resource type="PackedScene" path="res://scenes/components/dialogue_trigger.tscn" id="3_dialogue_trigger"]
[ext_resource type="Script" path="res://scripts/components/kamui_trigger.gd" id="4_kamui_script"]

[sub_resource type="RectangleShape2D" id="akatsuki_trigger_shape"]
size = Vector2(1152, 648)

[node name="AkatsukiHideout" type="Node2D"]
script = ExtResource("1_script")

[node name="UILayer" type="CanvasLayer" parent="."]

[node name="Background" type="TextureRect" parent="UILayer"]
anchor_right = 1.0
anchor_bottom = 1.0
texture = ExtResource("2_gedo2")
expand_mode = 1
stretch_mode = 6
mouse_filter = 2

[node name="DialogueTrigger" parent="." instance=ExtResource("3_dialogue_trigger")]
mode = "AUTO"
dialogue_id = "akatsuki_encontro"
one_shot = true

[node name="CollisionShape2D" parent="DialogueTrigger"]
shape = SubResource("akatsuki_trigger_shape")

[node name="KamuiTrigger" type="Node" parent="."]
script = ExtResource("4_kamui_script")
exit_position = Vector2(500, 0)
